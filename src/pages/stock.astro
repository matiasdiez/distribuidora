---
// /stock — Página pública de consulta de stock
// Estática (se cachea en el SW), el componente Svelte hace fetch de Supabase en el cliente
export const prerender = true;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0d0d0d" />
  <meta name="description" content="Consulta de stock del depósito" />
  <meta name="robots" content="noindex" /> <!-- no indexar en buscadores -->

  <title>Stock — Depósito</title>

  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div id="stock-app"></div>

  <script>
    import StockPublico from '../components/StockPublico.svelte';

    new StockPublico({ target: document.getElementById('stock-app') });
  </script>
</body>
</html>
