---
// /swipe — Interfaz de swipe entre productos por marca
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0d0d0d" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="description" content="Carga de stock por marca — Depósito" />

  <title>Swipe — Depósito</title>

  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
  <link rel="manifest" href="/manifest.json" />
</head>
<body>
  <div id="swipe-app"></div>
  <script>
    import { mount } from 'svelte';
    import SwipeProductos from '../components/SwipeProductos.svelte';
    mount(SwipeProductos, { target: document.getElementById('swipe-app') });
  </script>
</body>
</html>
